{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Compliance Result",
  "type": "object",
  "required": [
    "schema_version",
    "governance_repo",
    "target_repo",
    "timestamp",
    "status",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "governance_repo": {
      "type": "string"
    },
    "target_repo": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "description", "status"],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
