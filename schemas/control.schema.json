{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevSecOps Control Requirement Set",
  "type": "object",
  "required": ["level", "name", "required_platform_level", "requirements"],
  "properties": {
    "level": {
      "type": "string",
      "enum": ["L1", "L2", "L3", "GOV"]
    },
    "name": {
      "type": "string"
    },
    "required_platform_level": {
      "type": "string",
      "enum": ["PRA-Level 1", "PRA-Level 2", "PRA-Level 3", "Not applicable"]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
          "required": [
            "id",
            "domain",
            "title",
            "control_objective",
            "requirement",
            "verification_requirement",
            "required_platform_level",
            "platform_capabilities",
            "evidence",
            "verification",
            "automation",
            "policy_as_code",
            "waiver"
          ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DSCB-(L1|L2|L3|GOV)-REQ-[0-9]{3}$"
          },
          "domain": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "control_objective": {
            "type": "string"
          },
          "requirement": {
            "type": "string"
          },
          "verification_requirement": {
            "type": "string"
          },
          "required_platform_level": {
            "type": "string",
            "enum": ["PRA-Level 1", "PRA-Level 2", "PRA-Level 3", "Not applicable"]
          },
          "platform_capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verification": {
            "type": "object",
            "required": ["method", "frequency"],
            "properties": {
              "method": {
                "type": "string",
                "enum": ["automated", "manual", "hybrid"]
              },
              "frequency": {
                "type": "string"
              }
            }
          },
          "automation": {
            "type": "object",
            "required": ["type", "maturity", "check_type", "machine_readable_evidence_required", "rationale"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["blocking_gate", "warning_gate", "evidence_check", "review_check"]
              },
              "maturity": {
                "type": "string",
                "enum": ["immediate", "tool_integration_required", "future"]
              },
              "check_type": {
                "type": "string",
                "enum": ["presence", "linkage", "threshold", "configuration", "approval", "review", "integrity", "provenance"]
              },
              "machine_readable_evidence_required": {
                "type": "boolean"
              },
              "rationale": {
                "type": "string"
              }
            }
          },
          "policy_as_code": {
            "type": "object",
            "required": ["candidate", "enforcement"],
            "properties": {
              "candidate": { "type": "boolean" },
              "enforcement": { "type": "string" },
              "rule": { "type": "string" }
            }
          },
          "waiver": {
            "type": "object",
            "required": ["allowed", "authority"],
            "properties": {
              "allowed": { "type": "boolean" },
              "authority": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
