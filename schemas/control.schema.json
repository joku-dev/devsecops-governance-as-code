{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevSecOps Control Requirement",
  "type": "object",
  "required": [
    "id",
    "level",
    "domain",
    "title",
    "requirement",
    "required_platform_level",
    "evidence",
    "verification"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^DSCB-(L1|L2|L3|GOV)-REQ-[0-9]{3}$"
    },
    "level": {
      "type": "string",
      "enum": ["L1", "L2", "L3", "GOV"]
    },
    "domain": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "requirement": {
      "type": "string"
    },
    "required_platform_level": {
      "type": "string",
      "enum": ["PRA-Level 1", "PRA-Level 2", "PRA-Level 3", "Not applicable"]
    },
    "platform_capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "object",
      "required": ["method"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["automated", "manual", "hybrid"]
        },
        "frequency": {
          "type": "string"
        }
      }
    },
    "policy_as_code": {
      "type": "object",
      "properties": {
        "candidate": { "type": "boolean" },
        "enforcement": { "type": "string" },
        "rule": { "type": "string" }
      }
    },
    "waiver": {
      "type": "object",
      "properties": {
        "allowed": { "type": "boolean" },
        "authority": { "type": "string" }
      }
    }
  }
}
